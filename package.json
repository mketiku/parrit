{
  "name": "pairing",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "db": "supabase start -x studio,mailpit,logflare,vector,imgproxy",
    "db:admin": "supabase start",
    "db:stop": "supabase stop",
    "db:restart": "supabase stop && supabase start -x studio,mailpit,logflare,vector,imgproxy",
    "db:reset": "supabase db reset",
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "release:patch": "npm version patch -m \"v%s: [Patch] Automated version bump\"",
    "release:minor": "npm version minor -m \"v%s: [Minor] Automated version bump\"",
    "preversion": "npm run lint && npm run test && npm run typecheck",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react-dom": "^2.1.8",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.67.1",
    "@vercel/og": "^0.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.7",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.477.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-joyride": "^2.9.3",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.0.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "supabase": "^2.78.1",
    "tailwindcss": "4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^3.0.7"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
